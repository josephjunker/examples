{
    "compilerOptions": {
        "noEmit": true,

        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,

        "module": "nodenext",
        "rewriteRelativeImportExtensions": true,

        "strict": true,
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "moduleDetection": "auto",
        "skipLibCheck": true
    }
}
